resource "azurerm_resource_group" "{{ name | replace('-', '_') }}" {
  name     = "{{ name }}"
  location = "{{ location }}"
{% if tags is defined and tags %}

  tags = {
{% for key, value in tags.items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
{% endif %}
}

output "resource_group_name" {
  value = azurerm_resource_group.{{ name | replace('-', '_') }}.name
}

output "resource_group_location" {
  value = azurerm_resource_group.{{ name | replace('-', '_') }}.location
}
